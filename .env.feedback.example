# ========================================
# CONFIGURACIÓN DE NOTIFICACIONES DE FEEDBACK
# ========================================

# Auth0 Configuration (Requerido para obtener responsables)
AUTH0_ISSUER_BASE_URL=https://tu-tenant.auth0.com
API_CLIENT_ID=tu-client-id
API_CLIENT_SECRET=tu-client-secret
API_IDENTIFIER=https://tu-api-identifier/

# Configuración de Feedback
# Usar Auth0 para obtener responsables (recomendado)
FEEDBACK_USE_AUTH0=true

# Usar responsables específicos por tipo de servicio
FEEDBACK_USE_SERVICE_TYPE_EMAILS=true

# Enviar notificación al crear feedback
FEEDBACK_SEND_ON_CREATE=true

# Enviar notificación al aprobar feedback (opcional)
FEEDBACK_SEND_ON_APPROVE=false

# Enviar notificación al rechazar feedback (opcional)
FEEDBACK_SEND_ON_REJECT=false

# URL del panel de administración
ADMIN_DASHBOARD_URL=https://prodominicana.gob.do/admin/feedback

# ========================================
# FALLBACK (Solo si falla Auth0)
# ========================================
# Correos de respaldo si no se pueden obtener desde Auth0
FEEDBACK_EMAILS=fallback@prodominicana.gob.do,backup@prodominicana.gob.do

# ========================================
# PERMISOS EN AUTH0
# ========================================
# Los responsables se configuran asignando estos permisos a usuarios en Auth0:
#
# - manage:feedback              → Responsables generales (todos los feedbacks)
# - manage:feedback-all          → Alternativa (todos los feedbacks)
# - manage:feedback-investment   → Solo feedbacks de inversión
# - manage:feedback-export       → Solo feedbacks de exportación
# - manage:feedback-general      → Solo feedbacks generales
#
# Ver AUTH0-GUIDE.md para más detalles
